# MDCS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ---- API ----
# Base URL for the MDCS backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://api.mdcs.bank/v1

# ---- Auth ----
# JWT secret for cookie signing (server-side only — do NOT expose to client)
SESSION_SECRET=change_me_to_a_long_random_secret

# ---- Gemini AI ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Feature flags ----
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
